# Copy this file to .env and fill in real values for local development.
# In production (Render), set these as actual environment variables in
# the dashboard instead of committing a .env file.

# Flask session signing key — generate a real random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Port the app listens on (Render sets this automatically; only needed locally
# if you want something other than the Flask default of 5000)
PORT=5000
